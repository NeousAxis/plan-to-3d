{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "plan-to-3d building specification",
  "type": "object",
  "required": ["walls"],
  "properties": {
    "meta": {
      "type": "object",
      "properties": {
        "name": {"type": "string"},
        "units": {"type": "string", "default": "m"},
        "wall_height": {"type": "number", "default": 2.7, "description": "default wall height (m)"},
        "wall_thickness": {"type": "number", "default": 0.2, "description": "default wall thickness (m)"}
      },
      "additionalProperties": true
    },
    "walls": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["start", "end"],
        "properties": {
          "start": {"type": "array", "items": {"type": "number"}, "minItems": 2, "maxItems": 2},
          "end": {"type": "array", "items": {"type": "number"}, "minItems": 2, "maxItems": 2},
          "thickness": {"type": "number", "description": "overrides meta.wall_thickness"},
          "height": {"type": "number", "description": "overrides meta.wall_height"},
          "type": {"type": "string", "enum": ["exterior", "interior"]}
        }
      }
    },
    "openings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["wall"],
        "properties": {
          "wall": {"type": "integer", "description": "index into walls[]"},
          "kind": {"type": "string", "enum": ["door", "window"], "default": "window"},
          "position": {"type": "number", "minimum": 0, "maximum": 1, "description": "center as fraction of wall length"},
          "distance": {"type": "number", "description": "center in metres from wall start (overrides position)"},
          "width": {"type": "number", "default": 0.9},
          "height": {"type": "number", "description": "opening height (door ~2.1, window ~1.2)"},
          "sill": {"type": "number", "description": "bottom height (door 0, window ~0.9)"}
        }
      }
    },
    "slab": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean", "default": true},
        "thickness": {"type": "number", "default": 0.15},
        "margin": {"type": "number", "default": 0.0, "description": "extend slab beyond footprint (m)"}
      }
    },
    "roof": {
      "type": "object",
      "properties": {
        "type": {"type": "string", "enum": ["none", "flat", "gable"], "default": "none"},
        "height": {"type": "number", "description": "gable rise (m)"},
        "thickness": {"type": "number", "default": 0.2, "description": "flat roof slab thickness"},
        "overhang": {"type": "number", "default": 0.3},
        "ridge_axis": {"type": "string", "enum": ["x", "y"], "default": "x"}
      }
    },
    "rooms": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "at"],
        "properties": {
          "name": {"type": "string"},
          "at": {"type": "array", "items": {"type": "number"}, "minItems": 2, "maxItems": 2,
                 "description": "interior anchor point for the label (plan coords)"}
        }
      }
    },
    "furniture": {
      "type": "array",
      "description": "Interior furniture, appliances, fixtures, stairs. Each item is rendered as an oriented box (or a flight of steps for stairs).",
      "items": {
        "type": "object",
        "required": ["type", "at"],
        "properties": {
          "type": {
            "type": "string",
            "description": "Known: bed, single_bed, double_bed, king_bed, sofa, armchair, chair, stool, coffee_table, dining_table, table, desk, nightstand, counter, kitchen_counter, island, cabinet, wardrobe, closet, bookshelf, fridge, stove, oven, dishwasher, washing_machine, tv, sink, kitchen_sink, toilet, bathtub, shower, bidet, stairs, rug, generic. Unknown types fall back to a generic box."
          },
          "at": {
            "type": "array", "items": {"type": "number"}, "minItems": 2, "maxItems": 2,
            "description": "center of the footprint in plan coords (m)"
          },
          "size": {
            "type": "array", "items": {"type": "number"}, "minItems": 2, "maxItems": 2,
            "description": "footprint [width, depth] in metres BEFORE rotation. Defaults from the type."
          },
          "height": {"type": "number", "description": "object height (m). Defaults from the type. For stairs, total rise to climb."},
          "rotation": {"type": "number", "description": "rotation in degrees around the vertical axis (0 = width along plan X)"},
          "z": {"type": "number", "description": "base elevation (m). Default 0 (sitting on the slab). Use to wall-mount or stack."},
          "color": {"type": "array", "items": {"type": "number"}, "minItems": 3, "maxItems": 4,
                    "description": "optional override RGBA in [0..1]"},
          "steps": {"type": "integer", "description": "stairs only: number of treads (default ~ height/0.17)"},
          "name": {"type": "string", "description": "optional label (currently unused in viewer)"}
        }
      }
    }
  }
}
